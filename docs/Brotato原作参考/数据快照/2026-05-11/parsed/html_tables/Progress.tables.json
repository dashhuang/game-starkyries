    "row_count": 8,
    "rows": [
      {
        "Icon": "",
        "Name": "Give the money back",
        "Challenge": "Kill the Gobbler 5 times",
        "Unlocks": "Gobbler's Hat",
        "Unlock Type": "Item",
        "Notes": "The Gobbler appears randomly (3% chance after 10 seconds into the wave)"
      },
      {
        "Icon": "",
        "Name": "Ew, what's that smell?!",
        "Challenge": "Win a run in Danger 3 or more",
        "Unlocks": "Ban System",
        "Unlock Type": "Item",
        "Notes": "System, allows you to banish 8 items from the shop per run"
      },
      {
        "Icon": "",
        "Name": "Let's try this wave again",
        "Challenge": "During the last 5 seconds of a wave after wave 2, press 'Return to Main Menu'. Then press 'Resume' to try the wave again.",
        "Unlocks": "Hourglass",
        "Unlock Type": "Item",
        "Notes": ""
      },
      {
        "Icon": "",
        "Name": "Trick or Treat?",
        "Challenge": "Win a run without locking any items in the shop.",
        "Unlocks": "Candy Bag",
        "Unlock Type": "Item",
        "Notes": "Playing as a character like Gangster who can't lock items will make this simple. Lower difficulty levels also work."
      },
      {
        "Icon": "",
        "Name": "Mmm, so juicy!",
        "Challenge": "Collect 100 fruits while at maximum health",
        "Unlocks": "Fruit Basket",
        "Unlock Type": "Item",
        "Notes": "Characters who benefit from fruit at max health like Glutton or Farmer may get this achievement passively. Also consider Penguin."
      },
      {
        "Icon": "",
        "Name": "Smells like something's burning?",
        "Challenge": "Kill 30 enemies by burning them in a single wave",
        "Unlocks": "Will-o'-Wisp",
        "Unlock Type": "Item",
        "Notes": "A fire-focused Mage build should pick this up easily. Alternatively, as this seems to count enemies who died while on fire, any character with a Scared Sausage and lots of damage should do it."
      },
      {
        "Icon": "",
        "Name": "BooOOooOoo~",
        "Challenge": "Reach 70% Dodge",
        "Unlocks": "Ghost Outfit",
        "Unlock Type": "Item",
        "Notes": "Ghost is recommended"
      },
      {
        "Icon": "",
        "Name": "Crit Happens",
        "Challenge": "Reach 100% Crit Chance",
        "Unlocks": "Vorpal Sword",
        "Unlock Type": "Weapon",
        "Notes": "This is easiest to achieve in Endless mode by going for Crit Chance upgrades after you have a build going, as 100% Crit Chance is much higher than you'd normally aim for in a game."
      }
    ]
  },
  {
    "table_index": 3,
    "section": "The Abyss > Game Challenges (DLC)",
    "columns": [
      "Icon",
      "Name",
      "Challenge",
      "Unlocks",
      "Notes and Tips"
    ],
    "row_count": 9,
    "rows": [
      {
        "Icon": "",
        "Name": "Smelly Feet",
        "Challenge": "Walk a total of 20000 steps",
        "Unlocks": "Hiker",
        "Notes and Tips": "Unlocks automatically by playing multiple runs."
      },
      {
        "Icon": "",
        "Name": "Herbalist",
        "Challenge": "Collect 250 consumables by the end of wave 20",
        "Unlocks": "Druid",
        "Notes and Tips": "Playing a character based around consumables, like Farmer or Glutton makes this much easier to achieve."
      },
      {
        "Icon": "",
        "Name": "Unstoppable Force",
        "Challenge": "Hit at least 25 enemies with a single melee attack",
        "Unlocks": "Dwarf",
        "Notes and Tips": "Use big slow weapons such as Spear or Anchor and hit a ton of enemies. Look for a Horde Wave. You can also use Loud. The additional enemies makes it much easier to hit 25."
      },
      {
        "Icon": "",
        "Name": "Barbecue",
        "Challenge": "Have at least 25 enemies burning at the same time",
        "Unlocks": "Chef",
        "Notes and Tips": "Use a Fireball or Flamethrower to spread a ton of fire. You can try to find a Horde wave. Pacifist is great for this, since the burning enemies don't die."
      },
      {
        "Icon": "",
        "Name": "Unlucky",
        "Challenge": "Reroll 10 times in a single shop",
        "Unlocks": "Gangster",
